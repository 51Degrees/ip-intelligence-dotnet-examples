{
  // For a sample configuration file demonstrating all available options, see 
  // https://github.com/51Degrees/device-detection-dotnet-examples/blob/main/Examples/sample-configuration.json
  "PipelineOptions": {
    "Elements": [
      {
        "BuilderName": "CloudRequestEngine",
        // Obtain a resource key with all the properties used by this example
        // at https://configure.51degrees.com/hYzn3TV3. A free key from
        // https://configure.51degrees.com/Wkqxf3Bs will also work, but only
        // populates the free properties (Country, LocationConfidence, Ip and
        // IpV6).
        "BuildParameters": {
          "ResourceKey": "!!ENTER_YOUR_RESOURCE_KEY_HERE!!",
          "CloudRequestOrigin": "51Degrees.example.com"
        }
      },
      {
        "BuilderName": "IpiCloudEngine"
      },
      {
        // Consumes the country-name translations produced by the cloud service
        // (the cloud equivalent of the on-premise CountriesTranslationEngine)
        // and exposes them as ICountriesTranslationData. Must come after the
        // CloudRequestEngine so it can read that engine's JSON response.
        "BuilderName": "CloudCountriesTranslationEngine"
      },
      {
        "BuilderName": "JavaScriptBuilderElement",
        "BuildParameters": {
          "Minify": true
        }
      }
    ],
    // Both these options default to true anyway.
    // They are specified here for illustrative purposes.
    "ClientSideEvidenceEnabled": true,
    "UseAsyncScript": true
  }
}