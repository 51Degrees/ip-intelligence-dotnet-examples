@using System.Collections.Generic
@using FiftyOne.Pipeline.Core.Data
@using FiftyOne.Pipeline.Engines.Data
@model FiftyOne.IpIntelligence.Examples.Mixed.Cloud.GettingStartedWeb.Model.IndexModel
@{
    ViewData["Title"] = "Device Detection + IP Intelligence Example";
}

@functions {
    // Safely render a scalar property. Returns "Unknown" if the property is not
    // granted by the resource key (reading it throws PropertyMissingException)
    // or has no value. An optional formatter controls how the value is rendered.
    static string Show<T>(
        System.Func<IAspectPropertyValue<T>> get,
        System.Func<T, string> format = null)
    {
        try
        {
            var apv = get();
            if (apv == null || apv.HasValue == false) { return "Unknown"; }
            return format != null ? format(apv.Value) : apv.Value?.ToString() ?? "Unknown";
        }
        catch
        {
            return "Unknown";
        }
    }

    // Safely render a list property as a comma-separated string.
    static string ShowList(System.Func<IAspectPropertyValue<IReadOnlyList<string>>> get)
    {
        try
        {
            var apv = get();
            if (apv == null || apv.HasValue == false) { return "Unknown"; }
            return string.Join(", ", apv.Value);
        }
        catch
        {
            return "Unknown";
        }
    }
}

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="~/css/site.css" />

<h2>Combined Device Detection and IP Intelligence Example</h2>

<p>
    This example demonstrates the use of the Pipeline API to perform both device detection and
    IP intelligence lookups within a single ASP.NET Core web project. It highlights:
    <ol>
        <li>Device detection using User-Agent and Client Hints</li>
        <li>IP-based geolocation and network information</li>
        <li>Client-side evidence collection for enhanced detection</li>
        <li>Parallel processing of both engines for optimal performance</li>
    </ol>
</p>

<noscript>
    <div class="example-alert">
        WARNING: JavaScript is disabled in your browser. This means that client-side evidence
        collection will not work and some device properties may not be accurately detected.
    </div>
</noscript>

<div id="content">
    <!-- IP Address Input Form -->
    <form method="get" asp-action="Index" class="ip-form">
        <div>
            <label for="client-ip"><b>IP Address Lookup:</b></label>
            <input type="text" id="client-ip" name="client-ip" value="@Model.UserInputIp"
                   placeholder="e.g., 8.8.8.8">
            <button type="submit">Look Up</button>
        </div>
    </form>

    <div class="results-columns">
        <!-- Device Detection Results Column -->
        <div>
            <h3>Device Detection Results</h3>
            @if (!string.IsNullOrEmpty(Model.DeviceMessage))
            {
                <p class="device-summary">@Model.DeviceMessage</p>
            }
            <table>
                <tr>
                    <th>Property</th>
                    <th>Value</th>
                </tr>
                <tr class="lightyellow">
                    <td><b>Hardware Vendor:</b></td>
                    <td>@(Show(() => Model.Device.HardwareVendor))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Hardware Name:</b></td>
                    <td>@(ShowList(() => Model.Device.HardwareName))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Device Type:</b></td>
                    <td>@(Show(() => Model.Device.DeviceType))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Platform Vendor:</b></td>
                    <td>@(Show(() => Model.Device.PlatformVendor))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Platform Name:</b></td>
                    <td>@(Show(() => Model.Device.PlatformName))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Platform Version:</b></td>
                    <td>@(Show(() => Model.Device.PlatformVersion))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Browser Vendor:</b></td>
                    <td>@(Show(() => Model.Device.BrowserVendor))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Browser Name:</b></td>
                    <td>@(Show(() => Model.Device.BrowserName))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Browser Version:</b></td>
                    <td>@(Show(() => Model.Device.BrowserVersion))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Screen width (pixels):</b></td>
                    <td>@(Show(() => Model.Device.ScreenPixelsWidth))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Screen height (pixels):</b></td>
                    <td>@(Show(() => Model.Device.ScreenPixelsHeight))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Device Id:</b></td>
                    <td>@(Show(() => Model.Device.DeviceId))</td>
                </tr>
            </table>
        </div>

        <!-- IP Intelligence Results Column -->
        <div>
            <h3>IP Intelligence Results</h3>

            @if (!string.IsNullOrEmpty(Model.IpMessage))
            {
                <p class="ip-summary">@Model.IpMessage</p>
            }

            <table>
                <tr>
                    <th>Property</th>
                    <th>Value</th>
                </tr>
                <tr class="lightyellow">
                    <td><b>Registered Name:</b></td>
                    <td>@(Show(() => Model.IpData.RegisteredName))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Registered Owner:</b></td>
                    <td>@(Show(() => Model.IpData.RegisteredOwner))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Registered Country:</b></td>
                    <td>@(Show(() => Model.IpData.RegisteredCountry))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>IP Range Start:</b></td>
                    <td>@(Show(() => Model.IpData.IpRangeStart))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>IP Range End:</b></td>
                    <td>@(Show(() => Model.IpData.IpRangeEnd))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Country:</b></td>
                    <td>@(Show(() => Model.IpData.Country))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Country Code:</b></td>
                    <td>@(Show(() => Model.IpData.CountryCode))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Country Code 3:</b></td>
                    <td>@(Show(() => Model.IpData.CountryCode3))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Region:</b></td>
                    <td>@(Show(() => Model.IpData.Region))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>State:</b></td>
                    <td>@(Show(() => Model.IpData.State))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Town:</b></td>
                    <td>@(Show(() => Model.IpData.Town))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Latitude:</b></td>
                    <td>@(Show(() => Model.IpData.Latitude, v => v.ToString("F4")))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Longitude:</b></td>
                    <td>@(Show(() => Model.IpData.Longitude, v => v.ToString("F4")))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Areas:</b></td>
                    <td>@(Show(() => Model.IpData.Areas))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Accuracy Radius:</b></td>
                    <td>@(Show(() => Model.IpData.AccuracyRadiusMin))</td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Time Zone Offset:</b></td>
                    <td>@(Show(() => Model.IpData.TimeZoneOffset))</td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Country Codes Geographical:</b></td>
                    <td>
                        @{
                            IAspectPropertyValue<IReadOnlyList<IWeightedValue<string>>> countryCodesGeographical = null;
                            try
                            {
                                countryCodesGeographical = Model.IpData?.CountryCodesGeographical;
                            }
                            catch
                            {
                                // nop
                            }
                            if (countryCodesGeographical != null)
                            {
                                if (countryCodesGeographical.HasValue)
                                {
                                    <ul>
                                        @foreach (var c in countryCodesGeographical.Value)
                                        {
                                            <li>@c.Value (@(c.Weighting() * 100)%)</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    @(countryCodesGeographical.NoValueMessage ?? "(no value)")
                                }
                            }
                            else
                            {
                                <p>(Property Not Found)</p>
                            }
                        }
                    </td>
                </tr>
                <tr class="lightgreen">
                    <td><b>Country Codes Population:</b></td>
                    <td>
                        @{
                            IAspectPropertyValue<IReadOnlyList<IWeightedValue<string>>> countryCodesPopulation = null;
                            try
                            {
                                countryCodesPopulation = Model.IpData?.CountryCodesPopulation;
                            }
                            catch
                            {
                                // nop
                            }
                            if (countryCodesPopulation != null)
                            {
                                if (countryCodesPopulation.HasValue)
                                {
                                    <ul>
                                        @foreach (var c in countryCodesPopulation.Value)
                                        {
                                            <li>@c.Value (@(c.Weighting() * 100)%)</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    @(countryCodesPopulation.NoValueMessage ?? "(no value)")
                                }
                            }
                            else
                            {
                                <p>(Property Not Found)</p>
                            }
                        }
                    </td>
                </tr>
                <tr class="lightyellow">
                    <td><b>Countries (geographical):</b></td>
                    <td>
                        @* Dropdown of all countries ordered by geographical
                           weighting. Each option's value is the country code
                           while its text is the translated country name - the
                           two All lists are index-aligned. The accessors are
                           wrapped because a resource key may not grant these
                           properties (which would throw PropertyMissingException). *@
                        @{
                            IAspectPropertyValue<IReadOnlyList<string>> codesAll = null;
                            IAspectPropertyValue<IReadOnlyList<string>> namesAll = null;
                            try { codesAll = Model.Countries?.CountryCodesGeographicalAll; } catch { /* not granted */ }
                            try { namesAll = Model.Countries?.CountryNamesGeographicalAllTranslated; } catch { /* not granted */ }
                            if (codesAll != null && codesAll.HasValue
                                && namesAll != null && namesAll.HasValue
                                && codesAll.Value.Count == namesAll.Value.Count
                                && codesAll.Value.Count > 0)
                            {
                                <select>
                                    @for (var i = 0; i < codesAll.Value.Count; i++)
                                    {
                                        <option value="@codesAll.Value[i]">@namesAll.Value[i]</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <span>(no country list available)</span>
                            }
                        }
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <br />

    <!-- Evidence Section -->
    <div id="evidence">
        <h3>Evidence Used</h3>
        <p class="smaller">Evidence collected from the current request</p>
        <details>
            <summary>Click to view evidence details</summary>
            <table>
                <tr>
                    <th>Key</th>
                    <th>Value</th>
                </tr>
                @if (Model.Evidence != null)
                {
                    var index = 0;
                    @foreach (var entry in Model.Evidence)
                    {
                        <tr class="@(index % 2 == 0 ? "lightyellow" : "lightgreen")">
                            <td><b>@entry.Key</b></td>
                            <td>@(entry.Value.Length > 100 ? entry.Value.Substring(0, 100) + "..." : entry.Value)</td>
                        </tr>
                        index++;
                    }
                }
            </table>
        </details>
    </div>
</div>

@* Client-side JavaScript for evidence gathering and device detection callbacks.
    This View Component is provided by the FiftyOne.Pipeline.Web package.
    It generates the necessary JavaScript for client-side evidence collection
    and handles callbacks for enhanced device detection. *@
@await Component.InvokeAsync("FiftyOneJS")

<script>
    window.onload = function () {
        // Subscribe to the 'complete' event which fires when client-side evidence
        // has been collected and sent back to the server for enhanced detection.
        fod.complete(function (data) {
            console.log('51Degrees client-side evidence collection completed');
            console.log('Enhanced device data available:', data.device);

            // Optionally refresh the page to show updated results with client-side evidence
            // location.reload();
        });
    }
</script>
