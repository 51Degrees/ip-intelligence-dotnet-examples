@using FiftyOne.Pipeline.Core.Data
@model FiftyOne.IpIntelligence.Examples.Mixed.OnPremise.GettingStartedWeb.Model.IndexModel
@{
    ViewData["Title"] = "Device Detection + IP Intelligence Example";
}

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="~/css/examples-main.min.css" />

<div class="c-eg-page">
    <h2 class="c-eg-page__title">Combined device detection and IP intelligence example</h2>
    <p class="c-eg-page__lead">
        This example demonstrates the use of the Pipeline API to perform both device detection and
        IP intelligence lookups within a single ASP.NET Core web project. It highlights device
        detection using User-Agent and Client Hints, IP-based geolocation and network information,
        client-side evidence collection for enhanced detection, and parallel processing of both
        engines for optimal performance.
    </p>

    <noscript>
        <div class="c-eg-alert">
            WARNING: JavaScript is disabled in your browser. This means that client-side evidence
            collection will not work and some device properties may not be accurately detected.
        </div>
    </noscript>

    <div id="content">
        <form method="get" asp-action="Index" class="c-eg-form">
            <div class="c-eg-form__row">
                <label class="b-label" for="client-ip">IP Address Lookup:</label>
                <input class="b-input" type="text" id="client-ip" name="client-ip" value="@Model.UserInputIp"
                       placeholder="e.g., 8.8.8.8">
                <button class="b-btn" type="submit">Look Up</button>
            </div>
        </form>

        <div class="c-eg-columns">
            <div>
                <h3 class="c-eg-page__heading">Device detection results</h3>
                @if (!string.IsNullOrEmpty(Model.DeviceMessage))
                {
                    <p class="c-eg-page__lead">@Model.DeviceMessage</p>
                }
                <table class="c-eg-table">
                    <thead class="c-eg-table__head">
                        <tr class="c-eg-table__row">
                            <th class="c-eg-table__cell">Property</th>
                            <th class="c-eg-table__cell">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Hardware Vendor:</td><td class="c-eg-table__cell">@(Model.Device?.HardwareVendor?.HasValue == true ? string.Join(", ", Model.Device.HardwareVendor.Value) : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Hardware Name:</td><td class="c-eg-table__cell">@(Model.Device?.HardwareName?.HasValue == true ? string.Join(", ", Model.Device.HardwareName.Value) : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Device Type:</td><td class="c-eg-table__cell">@(Model.Device?.DeviceType?.HasValue == true ? Model.Device.DeviceType.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Platform Vendor:</td><td class="c-eg-table__cell">@(Model.Device?.PlatformVendor?.HasValue == true ? string.Join(", ", Model.Device.PlatformVendor.Value) : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Platform Name:</td><td class="c-eg-table__cell">@(Model.Device?.PlatformName?.HasValue == true ? Model.Device.PlatformName.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Platform Version:</td><td class="c-eg-table__cell">@(Model.Device?.PlatformVersion?.HasValue == true ? Model.Device.PlatformVersion.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Browser Vendor:</td><td class="c-eg-table__cell">@(Model.Device?.BrowserVendor?.HasValue == true ? string.Join(", ", Model.Device.BrowserVendor.Value) : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Browser Name:</td><td class="c-eg-table__cell">@(Model.Device?.BrowserName?.HasValue == true ? Model.Device.BrowserName.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Browser Version:</td><td class="c-eg-table__cell">@(Model.Device?.BrowserVersion?.HasValue == true ? Model.Device.BrowserVersion.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Screen width (pixels):</td><td class="c-eg-table__cell">@(Model.Device?.ScreenPixelsWidth?.HasValue == true ? Model.Device.ScreenPixelsWidth.Value.ToString() : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Screen height (pixels):</td><td class="c-eg-table__cell">@(Model.Device?.ScreenPixelsHeight?.HasValue == true ? Model.Device.ScreenPixelsHeight.Value.ToString() : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Device Id:</td><td class="c-eg-table__cell">@(Model.Device?.DeviceId?.HasValue == true ? Model.Device.DeviceId.Value : "Unknown")</td></tr>
                    </tbody>
                </table>
            </div>

            <div>
                <h3 class="c-eg-page__heading">IP intelligence results</h3>

                @if (!string.IsNullOrEmpty(Model.IpMessage))
                {
                    <p class="c-eg-page__lead">@Model.IpMessage</p>
                }

                <table class="c-eg-table">
                    <thead class="c-eg-table__head">
                        <tr class="c-eg-table__row">
                            <th class="c-eg-table__cell">Property</th>
                            <th class="c-eg-table__cell">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Registered Name:</td><td class="c-eg-table__cell">@(Model.IpData?.RegisteredName?.HasValue == true ? Model.IpData.RegisteredName.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Registered Owner:</td><td class="c-eg-table__cell">@(Model.IpData?.RegisteredOwner?.HasValue == true ? Model.IpData.RegisteredOwner.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Registered Country:</td><td class="c-eg-table__cell">@(Model.IpData?.RegisteredCountry?.HasValue == true ? Model.IpData.RegisteredCountry.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">IP Range Start:</td><td class="c-eg-table__cell">@(Model.IpData?.IpRangeStart?.HasValue == true ? Model.IpData.IpRangeStart.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">IP Range End:</td><td class="c-eg-table__cell">@(Model.IpData?.IpRangeEnd?.HasValue == true ? Model.IpData.IpRangeEnd.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Country:</td><td class="c-eg-table__cell">@(Model.IpData?.Country?.HasValue == true ? Model.IpData.Country.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Country Code:</td><td class="c-eg-table__cell">@(Model.IpData?.CountryCode?.HasValue == true ? Model.IpData.CountryCode.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Country Code 3:</td><td class="c-eg-table__cell">@(Model.IpData?.CountryCode3?.HasValue == true ? Model.IpData.CountryCode3.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Region:</td><td class="c-eg-table__cell">@(Model.IpData?.Region?.HasValue == true ? Model.IpData.Region.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">State:</td><td class="c-eg-table__cell">@(Model.IpData?.State?.HasValue == true ? Model.IpData.State.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Town:</td><td class="c-eg-table__cell">@(Model.IpData?.Town?.HasValue == true ? Model.IpData.Town.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Latitude:</td><td class="c-eg-table__cell">@(Model.IpData?.Latitude?.HasValue == true ? Model.IpData.Latitude.Value.ToString("F4") : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Longitude:</td><td class="c-eg-table__cell">@(Model.IpData?.Longitude?.HasValue == true ? Model.IpData.Longitude.Value.ToString("F4") : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Areas:</td><td class="c-eg-table__cell">@(Model.IpData?.Areas?.HasValue == true ? Model.IpData.Areas.Value : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt"><td class="c-eg-table__cell c-eg-table__cell--key">Accuracy Radius:</td><td class="c-eg-table__cell">@(Model.IpData?.AccuracyRadiusMin?.HasValue == true ? Model.IpData.AccuracyRadiusMin.Value.ToString() : "Unknown")</td></tr>
                        <tr class="c-eg-table__row"><td class="c-eg-table__cell c-eg-table__cell--key">Time Zone Offset:</td><td class="c-eg-table__cell">@(Model.IpData?.TimeZoneOffset?.HasValue == true ? Model.IpData.TimeZoneOffset.Value.ToString() : "Unknown")</td></tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt">
                            <td class="c-eg-table__cell c-eg-table__cell--key">Country Codes Geographical:</td>
                            <td class="c-eg-table__cell">
                                @if (Model.IpData?.CountryCodesGeographical.HasValue == true)
                                {
                                    <ul>
                                        @foreach (var c in Model.IpData.CountryCodesGeographical.Value)
                                        {
                                            <li>@c.Value (@(c.Weighting() * 100)%)</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    @(Model.IpData?.CountryCodesGeographical.NoValueMessage ?? "(no value)")
                                }
                            </td>
                        </tr>
                        <tr class="c-eg-table__row">
                            <td class="c-eg-table__cell c-eg-table__cell--key">Country Codes Population:</td>
                            <td class="c-eg-table__cell">
                                @if (Model.IpData?.CountryCodesPopulation.HasValue == true)
                                {
                                    <ul>
                                        @foreach (var c in Model.IpData.CountryCodesPopulation.Value)
                                        {
                                            <li>@c.Value (@(c.Weighting() * 100)%)</li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    @(Model.IpData?.CountryCodesPopulation.NoValueMessage ?? "(no value)")
                                }
                            </td>
                        </tr>
                        <tr class="c-eg-table__row c-eg-table__row--alt">
                            <td class="c-eg-table__cell c-eg-table__cell--key">Country Names Geographical All Translated:</td>
                            <td class="c-eg-table__cell">
                                @if (Model.TranslationData?.CountryNamesGeographicalAllTranslated.HasValue == true
                                    && Model.TranslationData?.CountryCodesGeographicalAll.HasValue == true)
                                {
                                    var geoNames = Model.TranslationData.CountryNamesGeographicalAllTranslated.Value;
                                    var geoCodes = Model.TranslationData.CountryCodesGeographicalAll.Value;
                                    <select id="CountryNamesGeographicalAllTranslated"
                                            name="CountryNamesGeographicalAllTranslated"
                                            class="form-control">
                                        @for (int i = 0; i < geoNames.Count; i++)
                                        {
                                            <option value="@geoCodes[i]">@geoNames[i]</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    @(Model.TranslationData?.CountryNamesGeographicalAllTranslated.NoValueMessage ?? "(no value)")
                                }
                            </td>
                        </tr>
                        <tr class="c-eg-table__row">
                            <td class="c-eg-table__cell c-eg-table__cell--key">Country Names Population All Translated:</td>
                            <td class="c-eg-table__cell">
                                @if (Model.TranslationData?.CountryNamesPopulationAllTranslated.HasValue == true
                                    && Model.TranslationData?.CountryCodesPopulationAll.HasValue == true)
                                {
                                    var popNames = Model.TranslationData.CountryNamesPopulationAllTranslated.Value;
                                    var popCodes = Model.TranslationData.CountryCodesPopulationAll.Value;
                                    <select id="CountryNamesPopulationAllTranslated"
                                            name="CountryNamesPopulationAllTranslated"
                                            class="form-control">
                                        @for (int i = 0; i < popNames.Count; i++)
                                        {
                                            <option value="@popCodes[i]">@popNames[i]</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    @(Model.TranslationData?.CountryNamesPopulationAllTranslated.NoValueMessage ?? "(no value)")
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="map-section" class="c-eg-map" style="display: none;">
            <h3 class="c-eg-map__title">Location Map</h3>
            <div id="map" class="c-eg-map__canvas"></div>
        </div>

        <details class="c-eg-details">
            <summary>Evidence used</summary>
            <p class="c-eg-page__lead">Evidence collected from the current request</p>
            <table class="c-eg-table">
                <thead class="c-eg-table__head">
                    <tr class="c-eg-table__row">
                        <th class="c-eg-table__cell">Key</th>
                        <th class="c-eg-table__cell">Value</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Evidence != null)
                    {
                        var index = 0;
                        @foreach (var entry in Model.Evidence)
                        {
                            <tr class="c-eg-table__row @(index % 2 == 0 ? "c-eg-table__row--alt" : "")">
                                <td class="c-eg-table__cell c-eg-table__cell--key">@entry.Key</td>
                                <td class="c-eg-table__cell">@(entry.Value.Length > 100 ? entry.Value.Substring(0, 100) + "..." : entry.Value)</td>
                            </tr>
                            index++;
                        }
                    }
                </tbody>
            </table>
        </details>
    </div>

    @if (Model.IsLiteDataFile)
    {
        <div class="c-eg-message">
            <p class="c-eg-message__text">Need more on-premise properties and features? <a href="https://51degrees.com/contact-us">Contact us</a> to explore the options.</p>
            <a class="b-btn c-eg-message__cta" href="https://51degrees.com/contact-us">Contact us</a>
        </div>
    }
</div>

@* Client-side JavaScript for evidence gathering and device detection callbacks.
    This View Component is provided by the FiftyOne.Pipeline.Web package.
    It generates the necessary JavaScript for client-side evidence collection
    and handles callbacks for enhanced device detection. The shared examples.js
    helper subscribes to the 'complete' event and appends a results table into
    #content. *@
@await Component.InvokeAsync("FiftyOneJS")

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/wellknown@0.5.0/wellknown.js"></script>
<script src="~/js/examples.min.js"></script>

<script>
    window.onload = function () {
        fodExamples.bindDeviceCallback({ targetId: "content" });
        fodExamples.initLocationMap({
            areasWkt: '@Html.Raw(Model.IpData?.Areas?.HasValue == true ? Model.IpData.Areas.Value.ToString().Replace("'", "\\'") : "")',
            latitude: '@(Model.IpData?.Latitude?.HasValue == true ? Model.IpData.Latitude.Value.ToString("F4") : "")',
            longitude: '@(Model.IpData?.Longitude?.HasValue == true ? Model.IpData.Longitude.Value.ToString("F4") : "")'
        });
    };
</script>
