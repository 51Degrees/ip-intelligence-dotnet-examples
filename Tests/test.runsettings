<?xml version="1.0" encoding="utf-8"?>
<!--
  Shared test settings for the IP Intelligence example test projects.

  The on-premise integration tests each build a real engine against the
  enterprise IP Intelligence data file, which is several gigabytes. Running
  more than one of those at a time (the default MSTest behaviour is to
  parallelize across CPU cores) loads several multi-GB engines into memory
  simultaneously, which exhausts RAM on CI runners and causes the job to time
  out. These settings force the heavy on-premise tests to run one at a time and
  bound the overall runtime so a stuck test fails cleanly instead of hanging the
  runner.

  Referenced from each test project's <RunSettingsFilePath> so it is applied by
  `dotnet test` regardless of how CI invokes the tests.
-->
<RunSettings>
  <RunConfiguration>
    <!-- Whole-session ceiling (ms) so a run can never hang the CI job. -->
    <TestSessionTimeout>600000</TestSessionTimeout>
  </RunConfiguration>
  <MSTest>
    <!-- Per-test ceiling (ms). Generous because loading the enterprise data
         file plus, e.g., enumerating all metadata can take well over a minute. -->
    <TestTimeout>240000</TestTimeout>
    <!-- Run tests serially: only one multi-GB engine is loaded at a time.
         Concurrency itself is still covered by
         TestGettingStartedOnPremise.GettingStarted_ParallelProcessing_IsConsistent,
         which exercises many concurrent requests against a single shared engine. -->
    <Parallelize>
      <Workers>1</Workers>
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>
</RunSettings>
